# ═══════════════════════════════════════════════════════
# Texno Ai Bot — .env fayli
# ═══════════════════════════════════════════════════════

# 🤖 Telegram Bot Token (@BotFather dan oling)
BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 🧠 OpenAI API Key (platform.openai.com dan oling)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 👑 Admin Telegram ID lari (vergul bilan ajrating)
# ID ni bilish uchun @userinfobot ga /start yuboring
ADMIN_IDS=123456789,987654321

# 👤 Admin username (@ belgisisiz) — to'lov uchun link
ADMIN_USERNAME=your_admin_username

# 📦 Railway Volume mount qilingan yo'l
# Railway da: Settings → Volumes → Mount Path = /data
VOLUME_PATH=/data

# ⚙️ Ixtiyoriy sozlamalar (o'zgartirmasangiz ham bo'ladi)
SUBSCRIPTION_DAYS=30
SUBSCRIPTION_PRICE_UZS=19999
DAILY_MESSAGE_LIMIT=50
